<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="800.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="TableroController">

   <children>

      <!-- TABLERO -->
      <ImageView fx:id="tablero" fitHeight="740.0" fitWidth="740.0" layoutX="30.0" layoutY="30.0" preserveRatio="true">

         <image>
            <Image url="@resources/image/tableroAjedrez.png" />
         </image>

      </ImageView>

      
      <Pane fx:id="capaPiezas" layoutX="30.0" layoutY="30.0" prefHeight="740.0" prefWidth="740.0">
         <children>
            <Button fx:id="btnReiniciar" layoutX="480.0" mnemonicParsing="false" prefHeight="30.0" prefWidth="91.0" style="-fx-background-color: Blue;" text="Reiniciar">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Button>
         </children></Pane>

      
      <Button fx:id="btnRendirse" layoutX="636.0" layoutY="32.0" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: red; -fx-text-fill: white;" text="Rendirse">

         <font>
            <Font name="System Bold" size="14.0" />
         </font>

      </Button>

      
      <Label fx:id="turno" layoutX="66.0" layoutY="34.0" text="Turno: Blanco" textFill="WHITE">

         <font>
            <Font name="System Bold" size="18.0" />
         </font>

      </Label>

   </children>
</Pane>
