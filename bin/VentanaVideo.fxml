<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="337.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="VentanaFinalController">

    <children>

        <!-- Fondo (GIF o imagen) -->
        <ImageView fitHeight="337.0" fitWidth="600.0" pickOnBounds="true">
            <image>
                <!--  ASEGÚRATE de que esté en /resources/image/ -->
                <Image url="@resources/image/FinDeLaPartida.gif" />
            </image>
        </ImageView>

        <!-- Botón volver a jugar -->
        <Button fx:id="btnVolverJugar" layoutX="230.0" layoutY="200.0" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Volver a jugar">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>

        <!-- Botón menú -->
        <Button fx:id="btnMenu" layoutX="240.0" layoutY="240.0" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Salir al menú">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>

    </children>

</Pane>
